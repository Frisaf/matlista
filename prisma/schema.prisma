// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Dishes {
  id            Int           @id @default(autoincrement())
  name          String        @db.VarChar(150)
  main          Main          @relation(fields: [mainId], references: [id])
  mainId        Int           @default(0)
  side          Side          @relation(fields: [sideId], references: [id])
  sideId        Int           @default(0)
  otherInfo     String        @db.VarChar(400)
  weekendWorthy WeekendWorthy @default(NO)
}

model User {
  id       Int    @id @default(autoincrement())
  name     String @unique
  password String
}

model Side {
  id         Int      @id @default(autoincrement())
  side String   @default("") @db.VarChar(150)
  dish       Dishes[]
}

model Main {
  id         Int      @id @default(autoincrement())
  main String   @default("") @db.VarChar(150)
  dish       Dishes[]
}

enum WeekendWorthy {
  YES
  NO
}
