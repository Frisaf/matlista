{% extends "components/layout.njk" %}
{% block content %}

{{ flash | safe }}
<h1>Ska vi äta...</h1>
<h2><em>{{ dish.name }}</em></h2>
<p>Huvudingrediens: {{ main }}</p>
{% if sides != "None" %}
<h3>Tillbehör</h3>
<ul>
    {% for side in sides %}
        <li>{{ side }}</li>
    {% endfor %}
</ul>
{% endif %}
{% if otherInfo != "" %}
    <h3>Övrig info</h3>
    <ul>
        {% for info in otherInfo %}
            <li>{{ info }}</li>
        {% endfor %}
    </ul>
{% endif %}

{% if dish.weekendWorthy == "YES" %}
    <p>Den här rätten är helgvärdig.</p>
{% else %}
    <p>Den här rätten är <strong>inte</strong> helgvärdig.</p>
{% endif %}

<button onclick="reloadPage()">Ny rätt</button>
<button onclick="showFilters()">Filter</button>
{% if filters != "" %}
    <span><a href="/" id="resetLink">Återställ filter</a></span>
{% endif %}
<div class="filters">
    <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#00000" onclick="closeFilters()"><path d="m256-200-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z"/></svg>
    <h3>Filter</h3>
    <p>Välj de ingredienser eller kriterier du vill filtrera efter.</p>
    <form class="filterForm">
        <fieldset class="weekendWorthy">
            <legend><h4>Helgvärdighet</h4></legend>
            <input name="weekendWorthy" type="radio" value="YES" id="yes">
            <label for="yes">Helgvärdig</label>
            <input name="weekendWorthy" type="radio" value="NO" id="no">
            <label for="no">Inte helgvärdig</label>
        </fieldset>
        <fieldset>
            <legend><h4>Huvudingredienser</h4></legend>
            {% for main in allMains %}
                <div>
                    <input name="{{ main.main }}" type="checkbox" class="mainFilter" id="{{ main.main }}">
                    <label for="{{ main.main }}">{{ main.main }}</label>
                </div>
            {% endfor %}
        </fieldset>
        <fieldset>
            <legend><h4>Tillbehör</h4></legend>
            {% for side in allSides %}
                <div>
                    <input name="{{ side.side }}" type="checkbox" class="sideFilter" id="{{ side.side }}">
                    <label for="{{ side.side }}">{{ side.side }}</label>
                </div>
            {% endfor %}
        </fieldset>
        <input type="submit" value="Ny rätt med filter" class="submitDish">
    </form>
    <p></p>
</div>

{% endblock %}